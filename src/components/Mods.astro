---
const mods = [
  {
    year: '2016',
    title: 'Jacksonville ownership enters the record',
    description:
      'Public entries place the car in Jacksonville in 2016, with owner notes beginning soon after joining USA7s.',
    type: 'provenance',
  },
  {
    year: '2017',
    title: 'Engine configuration discussed in service',
    description:
      'Owner reports driving with a 1500 pre-crossflow and shares period-correct sourcing notes.',
    type: 'powertrain',
  },
  {
    year: '2018',
    title: 'Theft and recovery documented',
    description:
      'Car, van, and trailer were reported stolen after Norcross British Fayre; follow-up posts document recovery and lessons learned.',
    type: 'provenance',
  },
  {
    year: '2021',
    title: 'Rewiring an ex-racer car',
    description:
      'Posts describe minimal surviving wiring from racing use and a practical near-original rewire strategy.',
    type: 'electrical',
  },
  {
    year: '2023',
    title: 'Shifter and cockpit details recorded',
    description:
      'Detailed photos and measurements show internal-remote shifter work, plus seat-belt anchor and cockpit fitment notes.',
    type: 'chassis',
  },
  {
    year: '2024',
    title: 'Identity and underbody references added',
    description:
      'VIN/tag placement notes and tunnel/belly-pan photos are shared to support originality checks and service access.',
    type: 'provenance',
  },
  {
    year: '2025',
    title: 'Pedal, exhaust, and drivetrain notes expanded',
    description:
      'Owner provides practical notes on pedal-bracket geometry, custom exhaust components, wheels/fenders, and gearbox-shifter compatibility.',
    type: 'worklog',
  },
];

const typeLabels: Record<string, string> = {
  provenance: 'Provenance',
  powertrain: 'Powertrain',
  electrical: 'Electrical',
  chassis: 'Chassis',
  worklog: 'Work log',
};
---

<section id="mods" class="mods">
  <div class="container">
    <p class="section-label">Archive timeline</p>
    <h2>Workshop Record<br /><em>&amp; Provenance</em></h2>
    <ol class="timeline">
      {mods.map((mod) => (
        <li class="entry">
          <div class="entry-meta">
            <span class="entry-year">{mod.year}</span>
            <span class={`entry-type type-${mod.type}`}>{typeLabels[mod.type]}</span>
          </div>
          <div class="entry-body">
            <h3>{mod.title}</h3>
            <p>{mod.description}</p>
          </div>
        </li>
      ))}
    </ol>
    <div class="sources">
      <h3>Source threads</h3>
      <ul>
        <li><a href="https://usa7s.net/ips/profile/1625-joe-petty/content/?all_activity=1" target="_blank" rel="noopener noreferrer">Everything posted by Joe Petty</a></li>
        <li><a href="https://usa7s.net/ips/topic/11982-stolen-7-in-norcross-ga/" target="_blank" rel="noopener noreferrer">Stolen 7 in Norcross Ga.</a></li>
        <li><a href="https://usa7s.net/ips/topic/15289-wire-harness-design-and-manufacturing/" target="_blank" rel="noopener noreferrer">Wire Harness Design and Manufacturing</a></li>
        <li><a href="https://usa7s.net/ips/topic/15341-series-2-exhaust/" target="_blank" rel="noopener noreferrer">Series 2 Exhaust</a></li>
        <li><a href="https://usa7s.net/ips/topic/14552-lotus-seven-s2-shifter/" target="_blank" rel="noopener noreferrer">Lotus Seven S2 Shifter</a></li>
        <li><a href="https://usa7s.net/ips/topic/14997-seking-vin-location-s/" target="_blank" rel="noopener noreferrer">Seking VIN location [s].</a></li>
      </ul>
      <p class="source-note">Where posts describe prior setups or alternatives, entries are retained as historical notes and not treated as current confirmed specification.</p>
    </div>
  </div>
</section>

<style>
  .mods {
    background: var(--bg-section);
    border-bottom: 1px solid var(--border);
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 3rem;
    color: var(--text);
  }

  h2 em {
    color: var(--accent);
    font-style: italic;
  }

  .timeline {
    list-style: none;
    border-left: 1px solid var(--border);
    padding-left: 0;
    margin-left: 0.5rem;
  }

  .entry {
    position: relative;
    padding: 0 0 2.5rem 2rem;
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1rem;
  }

  .entry::before {
    content: '';
    position: absolute;
    left: -4px;
    top: 0.4rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg);
  }

  .entry:last-child {
    padding-bottom: 0;
  }

  @media (max-width: 480px) {
    .entry {
      grid-template-columns: 1fr;
    }
  }

  .entry-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 0.1rem;
  }

  .entry-year {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }

  .entry-type {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.2rem 0.45rem;
    border-radius: 2px;
    width: fit-content;
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .type-provenance,
  .type-powertrain,
  .type-electrical,
  .type-chassis,
  .type-worklog {
    background: transparent;
  }

  .entry-body h3 {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .entry-body p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .sources {
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .sources h3 {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .sources ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.5rem;
  }

  .sources a {
    color: var(--text-muted);
  }

  .sources a:hover {
    color: var(--accent);
  }

  .source-note {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
