---
const specs = [
  {
    category: 'Factory-era context (Series II)',
    rows: [
      { label: 'Make', value: 'Lotus Cars (United Kingdom)' },
      { label: 'Model family', value: 'Lotus Seven / Super Seven' },
      { label: 'Series II production', value: '1960 to August 1968' },
      { label: 'Known S2 production total', value: 'About 1,310 examples' },
      { label: 'Layout', value: 'Front-engine, rear-wheel drive lightweight roadster' },
      { label: 'Typical S2 engines', value: 'Ford Kent-family 1340cc and 1499cc (period context)' },
    ],
  },
  {
    category: 'Established in the record',
    rows: [
      { label: 'Model and year', value: '1962 Lotus Super 7 (Series II)' },
      { label: 'Exterior presentation', value: 'British racing green body with yellow and chrome accents' },
      { label: 'Owner location', value: 'Jacksonville, FL' },
      { label: 'Jacksonville ownership', value: 'Documented in June 2016 posting' },
      { label: 'Racing history', value: 'Described as ex-racer in multiple posts' },
      { label: 'Transmission detail', value: 'Internal Remote arrangement discussed' },
      { label: 'Shifter detail', value: 'Custom-fabricated shifter documented' },
    ],
  },
  {
    category: 'Workshop evidence',
    rows: [
      { label: 'Wiring', value: 'Car rewired; near-original electrical layout retained' },
      { label: 'Exhaust', value: 'Maniflow 4-2-1, 1 3/4 flex, and custom tractor muffler' },
      { label: 'Wheels/tires', value: '5 1/2 x 13 Silverstone wheels with Kumho 155x13 noted' },
      { label: 'Fenders', value: '8" originals discussed; replacement pair later sourced' },
      { label: 'VIN notes', value: 'California VIN process (1971) and two state tags noted' },
    ],
  },
  {
    category: 'Pending confirmation',
    rows: [
      { label: 'Current engine displacement', value: 'Listed as 1340cc in one post and 1500 pre-crossflow in another' },
      { label: 'Current carburetor setup', value: 'Webers referenced historically; present setup not confirmed' },
      { label: 'Brake configuration', value: 'Pedal/master-cylinder details discussed; current setup not explicit' },
      { label: 'Final drive ratio', value: 'Not confirmed in sourced owner posts' },
      { label: 'Measured performance', value: 'No owner-verified dyno or timed figures found' },
    ],
  },
];
---

<section id="specs" class="specs">
  <div class="container">
    <p class="section-label">Exhibit card</p>
    <h2>Specification<br /><em>in Context</em></h2>
    <div class="spec-groups">
      {specs.map((group) => (
        <div class="spec-group">
          <h3>{group.category}</h3>
          <table>
            <tbody>
              {group.rows.map((row) => (
                <tr>
                  <th scope="row">{row.label}</th>
                  <td>{row.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .specs {
    border-bottom: 1px solid var(--border);
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 3rem;
    color: var(--text);
  }

  h2 em {
    color: var(--accent-light);
    font-style: italic;
  }

  .spec-groups {
    display: grid;
    gap: 2.5rem;
  }

  .spec-group h3 {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--chrome);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  tr {
    border-bottom: 1px solid var(--border);
  }

  tr:last-child {
    border-bottom: none;
  }

  th, td {
    padding: 0.65rem 0;
    font-size: 0.9rem;
    text-align: left;
    vertical-align: top;
  }

  th {
    font-weight: 400;
    color: var(--text-muted);
    width: 42%;
    padding-right: 1.5rem;
  }

  td {
    color: var(--text);
  }

  @media (max-width: 640px) {
    th, td {
      display: block;
      width: 100%;
      padding: 0.35rem 0;
    }

    th {
      padding-top: 0.75rem;
      padding-right: 0;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    td {
      padding-bottom: 0.75rem;
    }
  }
</style>
