---
---

<section class="hero">
  <div class="hero-inner">
    <p class="eyebrow">Series II &middot; 1962</p>
    <h1>
      Lotus<br />
      <em>Super 7</em>
    </h1>
    <p class="tagline">Simplify, then add lightness.</p>
    <div class="rule"></div>
    <ul class="hero-stats">
      <li>
        <span class="stat-value">396</span>
        <span class="stat-label">kg dry weight</span>
      </li>
      <li>
        <span class="stat-value">39</span>
        <span class="stat-label">bhp</span>
      </li>
      <li>
        <span class="stat-value">88"</span>
        <span class="stat-label">wheelbase</span>
      </li>
    </ul>
  </div>
  <div class="hero-bg" aria-hidden="true">
    <div class="stripe stripe-1"></div>
    <div class="stripe stripe-2"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 4rem 1.5rem;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.06;
  }

  .stripe {
    position: absolute;
    top: -20%;
    bottom: -20%;
    width: 45%;
    transform: skewX(-8deg);
  }

  .stripe-1 {
    right: 5%;
    background: var(--accent);
  }

  .stripe-2 {
    right: 25%;
    background: var(--text);
    opacity: 0.4;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }

  .eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(4rem, 14vw, 10rem);
    line-height: 0.95;
    color: var(--text);
    margin-bottom: 2rem;
  }

  h1 em {
    color: var(--accent);
    font-style: italic;
  }

  .tagline {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }

  .rule {
    width: 3rem;
    height: 1px;
    background: var(--accent);
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    list-style: none;
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .stat-value {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }

  .stat-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.35rem;
  }
</style>
